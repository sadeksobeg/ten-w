{
  "name": "tenegta-monorepo",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "@types/node": "20.12.12"
  },
  "workspaces": ["site"],
  "scripts": {
    "build": "npm run build -w tenegta-website",
    "dev": "npm run dev -w tenegta-website",
    "start": "npm run start -w tenegta-website",
    "lint": "npm run lint -w tenegta-website",
    "deploy:netlify": "npm run build && npx --yes netlify-cli deploy --prod",
    "deploy:vps": "powershell -ExecutionPolicy Bypass -File scripts/deploy-vps.ps1"
  }
}
