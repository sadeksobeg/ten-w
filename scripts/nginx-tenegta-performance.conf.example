# مثال إعداد Nginx لـ tenegta.com (Next.js على 127.0.0.1:3100)
# انسخ الأقسام داخل server { } في /etc/nginx/sites-available/tenegta.com
# ثم: sudo nginx -t && sudo systemctl reload nginx

# ضغط الاستجابات (gzip — متوفر افتراضياً على أغلب VPS)
gzip on;
gzip_vary on;
gzip_proxied any;
gzip_comp_level 5;
gzip_min_length 256;
gzip_types
  text/plain
  text/css
  text/javascript
  application/javascript
  application/json
  application/xml
  image/svg+xml;

# ملفات Next.js الثابتة — cache طويل (المسارات تحتوي hash)
location /_next/static/ {
    proxy_pass http://127.0.0.1:3100;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-Proto $scheme;
    add_header Cache-Control "public, max-age=31536000, immutable";
}

# صور public/
location /images/ {
    proxy_pass http://127.0.0.1:3100;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-Proto $scheme;
    add_header Cache-Control "public, max-age=86400, stale-while-revalidate=604800";
}

# باقي التطبيق
location / {
    proxy_pass http://127.0.0.1:3100;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_buffering on;
}
