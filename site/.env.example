# --- Core (set in Netlify: Site settings → Environment variables) ---
# Production: https://your-site.netlify.app — fixes metadata/JSON-LD (avoids localhost fallback in some contexts)
NEXT_PUBLIC_SITE_URL=

# Optional: override phone shown on /contact (E.164 and display label). If unset, translations are used.
# NEXT_PUBLIC_CONTACT_PHONE_RAW=+963953562654
# NEXT_PUBLIC_CONTACT_PHONE_DISPLAY=+963 953 562 654

# Analytics & integrations
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Contact form webhook (optional)
CONTACT_WEBHOOK_URL=

# Formspree backup delivery (default matches production form)
FORMSPREE_ENDPOINT=https://formspree.io/f/mojpylaa

# Pilots showcase embed: YouTube or Vimeo watch URL
NEXT_PUBLIC_SHOWCASE_VIDEO_URL=

# Strapi CMS (optional — site uses built-in fallback content if unset)
STRAPI_URL=
STRAPI_API_TOKEN=

# --- Additional (optional) ---
# Tech stack hero MP4 URL
NEXT_PUBLIC_TECH_HERO_VIDEO_URL=

# WhatsApp Business E.164
NEXT_PUBLIC_WHATSAPP_E164=

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Social links
NEXT_PUBLIC_SOCIAL_LINKEDIN=
NEXT_PUBLIC_SOCIAL_X=
