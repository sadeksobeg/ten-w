# Copy to `.env` in this folder (`site/`). Prisma CLI reads `.env` here.
#   copy .env.example .env
#
# Local dev: PostgreSQL (Docker example below) or Neon/Supabase free tier.
#   docker run -d --name tenegta-pg -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=tenegta -p 5432:5432 postgres:16
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tenegta?schema=public"
#
# Optional: same URL when using Prisma Accelerate / PgBouncer (migrations use DIRECT_URL)
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/tenegta?schema=public"

# Auth.js / NextAuth (v5)
AUTH_SECRET="replace-with-a-long-random-string"

AUTH_URL="http://localhost:3000"

# Growth admin login also works at /admin/login (invite system)
# Invite system is additive-only: new InviteCard table; partner accounts unchanged
GROWTH_ADMIN_PASSWORD="ChangeMeAdmin!123"
GROWTH_DEMO_PASSWORD="ChangeMePartner!123"

# Sentry (optional)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Upstash Redis rate limiting (optional — falls back to in-memory in dev)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
