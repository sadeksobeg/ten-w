# Copy to `.env` in this folder (`site/`). Prisma CLI reads `.env` here.
#   copy .env.example .env
#
# Local dev (no PostgreSQL): SQLite file next to the schema.
DATABASE_URL="file:./dev.db"
#
# Production: use PostgreSQL instead, then set `provider = "postgresql"` in
# `prisma/schema.prisma` and point DATABASE_URL at your server, e.g.:
# DATABASE_URL="postgresql://USER:PASSWORD@host:5432/tenegta_growth?schema=public"

# Auth.js / NextAuth (v5)
AUTH_SECRET="replace-with-a-long-random-string"

AUTH_URL="http://localhost:3000"

GROWTH_ADMIN_PASSWORD="ChangeMeAdmin!123"
GROWTH_DEMO_PASSWORD="ChangeMePartner!123"
