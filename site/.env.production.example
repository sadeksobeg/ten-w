# =============================================================================
# T.E.N.E.G.T.A — Production environment template
# Netlify: copy into Site → Environment variables
# VPS (tenegta.com): use site/.env.vps.example → cp to site/.env — see docs/DEPLOY-VPS.md
# Run locally: npm run check:env  (after exporting vars or using a .env file)
# =============================================================================

# VPS only (self-hosted Node):
# NODE_ENV=production
# PORT=3100

# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────
# PostgreSQL (Neon, Supabase, RDS, etc.). Required for Growth platform + auth users.
# For local dev with SQLite instead: change provider in prisma/schema.prisma to "sqlite"
# and use DATABASE_URL="file:./dev.db"
#
# Serverless / PgBouncer (Neon, Supabase pooler): append query params, e.g.
#   ?pgbouncer=true&connection_limit=1
# Use DIRECT_URL (non-pooled) for `prisma migrate deploy` when your host provides it.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/tenegta?schema=public"
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/tenegta?schema=public"

# ─────────────────────────────────────────────
# AUTH
# ─────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="replace-with-long-random-string"
# Must match public site URL (no trailing slash)
AUTH_URL="https://www.your-domain.com"
# Growth partner portal (change before launch)
GROWTH_ADMIN_PASSWORD="strong-admin-password"
GROWTH_DEMO_PASSWORD="strong-demo-password"

# ─────────────────────────────────────────────
# CONTACT
# ─────────────────────────────────────────────
# At least ONE of the following is required (check-env enforces this).
# Formspree form endpoint (https://formspree.io/f/xxxx)
FORMSPREE_ENDPOINT="https://formspree.io/f/your-form-id"
# Optional CRM/webhook (Zapier, Make, HubSpot) — can be used alongside Formspree
CONTACT_WEBHOOK_URL="https://hooks.example.com/contact"
# Cloudflare Turnstile (recommended in production)
TURNSTILE_SECRET_KEY=""
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
# Optional display overrides
NEXT_PUBLIC_CONTACT_PHONE_RAW="+963953562654"
NEXT_PUBLIC_CONTACT_PHONE_DISPLAY="+963 953 562 654"
NEXT_PUBLIC_WHATSAPP_E164="+963953562654"

# ─────────────────────────────────────────────
# ANALYTICS
# ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://www.your-domain.com"
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"
# Optional social links (footer)
NEXT_PUBLIC_SOCIAL_LINKEDIN=""
NEXT_PUBLIC_SOCIAL_X=""

# ─────────────────────────────────────────────
# MONITORING
# ─────────────────────────────────────────────
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
# Upstash Redis — rate limiting across serverless instances (recommended)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─────────────────────────────────────────────
# CDN / MEDIA (public URLs, no secrets)
# ─────────────────────────────────────────────
# Tech stack hero background video (direct MP4 URL)
NEXT_PUBLIC_TECH_HERO_VIDEO_URL="https://cdn.example.com/tech-hero.mp4"
# Pilots showcase embed
NEXT_PUBLIC_SHOWCASE_VIDEO_URL="https://www.youtube.com/watch?v=VIDEO_ID"
# Optional: founder portrait (falls back to animated avatar if unset)
NEXT_PUBLIC_TEAM_LEAD_PORTRAIT_URL=""
# Optional headless CMS
STRAPI_URL=""
STRAPI_API_TOKEN=""
# Legacy demo API (pilots page) — omit if unused
NEXT_PUBLIC_API_URL=""
NEXT_PUBLIC_TENANT_ID=""

# ─────────────────────────────────────────────
# NETLIFY (often auto-injected — do not duplicate manually)
# ─────────────────────────────────────────────
# URL=https://deploy-preview-xxx.netlify.app
# DEPLOY_PRIME_URL=https://www.your-domain.com
