# =============================================================================
# T.E.N.E.G.T.A — VPS production environment
# DO NOT commit real secrets. Used only on your PC, then uploaded by deploy script.
#
# Auto-generated by: npm run setup:vps
# Deploy: npm run deploy:vps  — or both: npm run vps
# =============================================================================

# ── Core (required) ──────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3100

DATABASE_URL="postgresql://tenegta_user:Tenegta2025Secure@127.0.0.1:5432/tenegta_db"

# Generate on server: openssl rand -base64 32
AUTH_SECRET="PASTE_OUTPUT_OF_openssl_rand_base64_32"

AUTH_URL="https://tenegta.com"
NEXT_PUBLIC_SITE_URL="https://tenegta.com"

# Contact — set at least one (required by check:env). Recommended: Mailcow SMTP on VPS.
SMTP_HOST="127.0.0.1"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="info@tenegta.com"
SMTP_PASS="your-mailcow-app-password"
CONTACT_EMAIL_TO="info@tenegta.com"
SMTP_FROM="TENEGTA Website <info@tenegta.com>"
# FORMSPREE_ENDPOINT="https://formspree.io/f/your-form-id"
# CONTACT_WEBHOOK_URL="https://hooks.example.com/contact"

# ── Growth admin (change before launch) ──────────────────────────────────────
GROWTH_ADMIN_PASSWORD="change-me-strong-admin"
GROWTH_DEMO_PASSWORD="change-me-strong-demo"

# ── Optional: Turnstile, analytics, Sentry ───────────────────────────────────
# TURNSTILE_SECRET_KEY=""
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
# NEXT_PUBLIC_GA_MEASUREMENT_ID=""
# SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_DSN=""
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# ── Optional: contact display ───────────────────────────────────────────────
NEXT_PUBLIC_CONTACT_PHONE_RAW="+963953562654"
NEXT_PUBLIC_CONTACT_PHONE_DISPLAY="+963 953 562 654"
NEXT_PUBLIC_WHATSAPP_E164="+963953562654"
