generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Production: postgresql (Neon, Supabase, etc.). For local dev with SQLite:
  // change provider to "sqlite" and DATABASE_URL="file:./dev.db"
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PARTNER
  ADMIN
}

enum DealStatus {
  PENDING
  CLOSED
  LOST
}

enum PayoutStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
}

enum BadgeType {
  AUTO
  ADMIN
}

enum BadgeCategory {
  FINANCIAL
  SOCIAL
  BEHAVIORAL
  META
}

enum DemoSessionStatus {
  RUNNING
  COMPLETED
  ABORTED
}

enum ChatConversationStatus {
  OPEN
  RESOLVED
}

enum ChatPriority {
  HIGH
  NORMAL
  LOW
}

enum EventStatus {
  DRAFT
  PUBLISHED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ParticipantStatus {
  PENDING
  ACCEPTED
  COMPLETED
  WITHDRAWN
}

enum GrowthRewardStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  EVENT_INVITE
  EVENT_REMINDER
  EVENT_MILESTONE
  BADGE_EARNED
  LEVEL_UP
  XP_BOOST
  PAYOUT_UPDATE
  DEAL_CLOSED
  SYSTEM
  ADMIN_MESSAGE
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  emailVerified    DateTime?
  passwordHash     String
  name             String?
  image            String?
  phone            String?
  avatarUrl        String?   @db.Text
  avatarPreset     String?
  lastSeenAt       DateTime?
  bio              String?
  publicSlug       String?   @unique
  isActive         Boolean   @default(true)
  role             UserRole  @default(PARTNER)
  isVerifiedOfficial Boolean @default(false)
  officialDisplayName String?
  marketingKitHits Int       @default(0)
  pushSubscription String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  partnerProfile   PartnerProfile?
  referredPartners PartnerProfile[]   @relation("PartnerUpline")
  userBadges       UserBadge[]        @relation("UserBadgeSubject")
  xpEvents         XpEvent[]
  streak           UserStreak?
  payouts          PayoutRequest[]
  deals            Deal[]             @relation("DealPartner")
  commissionRows   CommissionLedger[]
  badgesGranted    UserBadge[]        @relation("UserBadgeGranter")
  missionDays              UserMissionDay[]
  missionRewardsReviewed   UserMissionDay[]     @relation("MissionRewardReviewed")
  pendingChainRewards      PendingChainReward[]
  chainRewardsReviewed     PendingChainReward[] @relation("ChainRewardReviewed")
  commissionOverrides PartnerCommissionOverride[] @relation("PartnerCommissionOverridePartner")
  leaderboardGrants   LeaderboardGrantLog[]
  demoSessions        DemoSession[]               @relation("DemoSessionCreator")
  chatConversationsAsPartner ChatConversation[]  @relation("ChatPartnerConversations")
  chatMessagesSent           ChatMessage[]        @relation("ChatMessageSender")
  chatRoomMembers            ChatRoomMember[]
  chatRoomMessagesSent       ChatRoomMessage[]    @relation("ChatRoomMessageSender")
  notifications              Notification[]
  eventsCreated              GrowthEvent[]        @relation("EventCreator")
  eventParticipants          EventParticipant[]
  eventPosts                 EventPost[]
  activityDays               UserActivityDay[]
  adminAuditLogs             AdminAuditLog[]    @relation("AdminAuditActor")
}

model PartnerProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  referralCode   String   @unique
  parentUserId   String?
  currentLevelId String
  totalXp        Int      @default(0)
  displayTitle   String?
  socialLinks      Json?
  showcasedBadges  String[] @default([])
  profileViews     Int      @default(0)
  leaderboardScoreBonus Int @default(0)
  onboardingSteps  Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent       User?           @relation("PartnerUpline", fields: [parentUserId], references: [id])
  currentLevel LevelDefinition @relation(fields: [currentLevelId], references: [id])

  @@index([parentUserId])
  @@index([referralCode])
}

model LevelDefinition {
  id             String   @id @default(cuid())
  order          Int      @unique
  code           String   @unique
  name           String
  minClosedDeals Int
  minXp          Int      @default(0)
  salaryUsd      Int?
  perksJson      Json?

  partnerProfiles PartnerProfile[]
}

model Product {
  id                    String  @id @default(cuid())
  slug                  String  @unique
  name                  String
  priceCents            Int
  commissionBaseCents   Int
  marketingKit          Json?
  active                Boolean @default(true)

  deals               Deal[]
  commissionOverrides PartnerCommissionOverride[]
}

model CommissionTierConfig {
  id         String   @id @default(cuid())
  tier1Bps   Int      @default(10000)
  tier2Bps   Int      @default(1000)
  tier3Bps   Int      @default(500)
  updatedAt  DateTime @updatedAt
}

model Deal {
  id              String     @id @default(cuid())
  partnerId       String
  productId       String
  status          DealStatus @default(PENDING)
  saleAmountCents Int
  notes           String?
  clientLabel     String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  closedAt        DateTime?
  lostAt          DateTime?

  partner  User                 @relation("DealPartner", fields: [partnerId], references: [id])
  product  Product              @relation(fields: [productId], references: [id])
  ledger   CommissionLedger[]
  xpEvents XpEvent[]            @relation("XpDeal")
  linkedConversations ChatConversation[] @relation("ChatLinkedDeal")

  @@index([partnerId, status])
  @@index([closedAt])
}

model CommissionLedger {
  id          String   @id @default(cuid())
  dealId      String?
  userId      String
  tier        Int
  amountCents Int
  ruleSnapshot Json?
  createdAt   DateTime @default(now())

  deal Deal? @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([dealId])
}

model BadgeDefinition {
  id          String        @id @default(cuid())
  key         String        @unique
  name        String
  type        BadgeType
  category    BadgeCategory @default(META)
  hidden      Boolean       @default(false)
  iconKey     String?
  description String?
  criteria    Json?

  userBadges UserBadge[]
}

model UserBadge {
  id           String   @id @default(cuid())
  userId       String
  badgeId      String
  grantedAt    DateTime @default(now())
  grantedById  String?

  user      User            @relation("UserBadgeSubject", fields: [userId], references: [id], onDelete: Cascade)
  badge     BadgeDefinition @relation(fields: [badgeId], references: [id])
  grantedBy User?           @relation("UserBadgeGranter", fields: [grantedById], references: [id])

  @@unique([userId, badgeId])
}

model XpEvent {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  reason    String
  source    String?
  dealId    String?
  createdAt DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal Deal? @relation("XpDeal", fields: [dealId], references: [id])

  @@index([userId, createdAt])
}

model UserStreak {
  userId          String    @id
  currentStreak   Int       @default(0)
  longestStreak   Int       @default(0)
  lastActiveDate   DateTime?
  lastCheckInDate  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PayoutRequest {
  id          String       @id @default(cuid())
  userId      String
  amountCents Int
  status      PayoutStatus @default(PENDING)
  method      String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, status])
}

model MissionDefinition {
  id         String   @id @default(cuid())
  key        String   @unique
  title      String
  xpReward   Int
  criteria   Json
  chainGroup String?
  sortOrder  Int      @default(0)
  active     Boolean  @default(true)
}

model AdminAuditLog {
  id        String   @id @default(cuid())
  actorId   String
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  actor User @relation("AdminAuditActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId])
  @@index([createdAt])
}

model UserMissionDay {
  id           String              @id @default(cuid())
  userId       String
  missionKey   String
  day          String
  progress     Int                 @default(0)
  completedAt  DateTime?
  rewardStatus GrowthRewardStatus  @default(NONE)
  rewardXp     Int?
  reviewedAt   DateTime?
  reviewedById String?

  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("MissionRewardReviewed", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@unique([userId, missionKey, day])
  @@index([userId, day])
  @@index([rewardStatus])
}

model PendingChainReward {
  id             String             @id @default(cuid())
  userId         String
  chainGroup     String
  day            String
  xpAmount       Int
  rewardStatus   GrowthRewardStatus @default(PENDING)
  reviewedAt     DateTime?
  reviewedById   String?
  createdAt      DateTime           @default(now())

  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("ChainRewardReviewed", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@unique([userId, chainGroup, day])
  @@index([rewardStatus])
}

model LeaderboardRewardRule {
  id         String   @id @default(cuid())
  name       String
  windowMs   BigInt
  rankMin    Int
  rankMax    Int
  bonusCents Int      @default(0)
  badgeKey   String?
  active     Boolean  @default(true)
}

/// Active scoring weights for partner leaderboards (composite: deals + XP + streak).
model LeaderboardSeason {
  id           String   @id @default(cuid())
  name         String
  windowMs     BigInt
  weightDeals  Int      @default(40)
  weightXp     Int      @default(40)
  weightStreak Int      @default(20)
  active       Boolean  @default(true)
  startsAt     DateTime @default(now())
  endsAt       DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([active])
}

/// One row per partner per UTC day they opened the dashboard (activity heatmap).
model UserActivityDay {
  id     String   @id @default(cuid())
  userId String
  day    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, day])
  @@index([userId])
}

model LeaderboardGrantLog {
  id         String   @id @default(cuid())
  userId     String
  periodKey  String
  rank       Int
  ruleId     String?
  bonusCents Int      @default(0)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, periodKey])
}

model PartnerCommissionOverride {
  id                  String   @id @default(cuid())
  partnerUserId       String
  productId           String?
  commissionBaseCents Int?
  note                String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  partner User    @relation("PartnerCommissionOverridePartner", fields: [partnerUserId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([partnerUserId])
}

model ActivityEvent {
  id          String   @id @default(cuid())
  kind        String
  actorUserId String?
  headline    String
  amountCents Int?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model DemoSession {
  id             String            @id @default(cuid())
  createdById    String
  status         DemoSessionStatus @default(RUNNING)
  scriptVariant  String?
  startedAt      DateTime          @default(now())
  endedAt        DateTime?

  creator User        @relation("DemoSessionCreator", fields: [createdById], references: [id], onDelete: Cascade)
  events  DemoEvent[]

  @@index([createdById, startedAt])
}

model ChatConversation {
  id            String                 @id @default(cuid())
  partnerUserId String
  status        ChatConversationStatus @default(OPEN)
  priority      ChatPriority           @default(NORMAL)
  linkedDealId  String?
  subject       String?
  lastMessageAt       DateTime?
  partnerLastReadAt   DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  partner   User          @relation("ChatPartnerConversations", fields: [partnerUserId], references: [id], onDelete: Cascade)
  linkedDeal Deal?        @relation("ChatLinkedDeal", fields: [linkedDealId], references: [id], onDelete: SetNull)
  messages  ChatMessage[]

  @@index([partnerUserId, status])
  @@index([lastMessageAt])
  @@index([priority])
}

model ChatMessage {
  id             String   @id @default(cuid())
  conversationId String
  senderUserId   String
  body           String
  kind           String   @default("TEXT")
  metadata       Json?
  createdAt      DateTime @default(now())

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User             @relation("ChatMessageSender", fields: [senderUserId], references: [id])

  @@index([conversationId, createdAt])
}

enum ChatRoomType {
  COMMUNITY
  EVENT
  CREATOR
}

model ChatRoom {
  id        String       @id @default(cuid())
  slug      String       @unique
  type      ChatRoomType @default(COMMUNITY)
  title     String
  isPublic  Boolean      @default(true)
  eventId   String?      @unique
  createdAt DateTime     @default(now())

  event    GrowthEvent? @relation(fields: [eventId], references: [id], onDelete: Cascade)
  members  ChatRoomMember[]
  messages ChatRoomMessage[]
}

model ChatRoomMember {
  roomId   String
  userId   String
  joinedAt DateTime @default(now())

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([roomId, userId])
  @@index([userId])
}

model ChatRoomMessage {
  id           String   @id @default(cuid())
  roomId       String
  senderUserId String
  body         String
  kind         String   @default("TEXT")
  metadata     Json?
  isOfficial   Boolean  @default(false)
  triggerKey   String?
  createdAt    DateTime @default(now())

  room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender User     @relation("ChatRoomMessageSender", fields: [senderUserId], references: [id])

  @@index([roomId, createdAt])
}

model DemoEvent {
  id        String   @id @default(cuid())
  sessionId String
  seq       Int
  kind      String
  delayMs   Int      @default(900)
  payload   Json

  session DemoSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, seq])
  @@index([sessionId])
}

model GrowthEvent {
  id              String      @id @default(cuid())
  slug            String      @unique
  title           String
  description     String
  rules           String
  startAt         DateTime
  endAt           DateTime?
  maxParticipants Int?
  coverImage      String?     @db.Text
  status          EventStatus @default(DRAFT)
  createdById     String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  creator      User               @relation("EventCreator", fields: [createdById], references: [id], onDelete: Cascade)
  participants EventParticipant[]
  milestones   EventMilestone[]
  eventNotifications EventNotification[]
  posts        EventPost[]
  chatRoom     ChatRoom?

  @@index([status])
  @@index([startAt])
}

enum EventPostKind {
  POST
  REPOST
}

model EventPost {
  id         String        @id @default(cuid())
  eventId    String
  userId     String
  body       String        @db.Text
  kind       EventPostKind @default(POST)
  repostOfId String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  event    GrowthEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  repostOf EventPost?  @relation("EventRepost", fields: [repostOfId], references: [id], onDelete: SetNull)
  reposts  EventPost[] @relation("EventRepost")

  @@index([eventId, createdAt])
  @@index([userId])
}

model EventParticipant {
  id            String            @id @default(cuid())
  eventId       String
  userId        String
  status        ParticipantStatus @default(PENDING)
  joinedAt      DateTime?
  progress      Int               @default(0)
  xpEarned      Int               @default(0)
  acceptedRules Boolean           @default(false)
  acceptedAt    DateTime?
  rewardedMilestones Json?

  event GrowthEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId])
}

model EventMilestone {
  id               String @id @default(cuid())
  eventId          String
  title            String
  description      String?
  xpReward         Int    @default(0)
  order            Int
  requiredProgress Int    @default(0)

  event GrowthEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  link      String?
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventNotifications EventNotification[]

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model EventNotification {
  id             String @id @default(cuid())
  eventId        String
  notificationId String

  event        GrowthEvent  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@unique([eventId, notificationId])
}
